[
	// Vim escape
	{
		"key": "escape",
		"command": "-extension.vim_escape",
		"when": "editorTextFocus && vim.active && !inDebugRepl"
	},
	{
		"key": "escape",
		"command": "extension.vim_escape",
		"when": "editorTextFocus && !inDebugRepl && !suggestWidgetVisible"
	},
	// Vim cursor movement with word-wrap
	{
		"key": "up",
		"command": "cursorUp",
		"when": "editorTextFocus && vim.active && !inDebugRepl && vim.mode == 'Insert' &&!suggestWidgetMultipleSuggestions && !suggestWidgetVisible"
	},
	{
		"key": "down",
		"command": "cursorDown",
		"when": "editorTextFocus && vim.active && !inDebugRepl && vim.mode == 'Insert' && !suggestWidgetMultipleSuggestions && !suggestWidgetVisible"
	},
	// Vim else
	{
		"key": "alt+tab",
		"command": "extension.vim_ctrl+space",
		"when": "editorTextFocus && vim.active && vim.use<C-space> && !inDebugRepl && vim.mode != 'Insert'"
	},
	{
		"key": "ctrl+space",
		"command": "-extension.vim_ctrl+space",
		"when": "editorTextFocus && vim.active && vim.use<C-space> && !inDebugRepl && vim.mode != 'Insert'"
	},
	{
		"key": "cmd+d",
		"command": "-extension.vim_cmd+d",
		"when": "editorTextFocus && vim.active && vim.use<D-d> && !inDebugRepl"
	},
	// tab behavior
	{
		"key": "tab",
		"command": "-acceptSelectedSuggestion",
		"when": "suggestWidgetHasFocusedSuggestion && suggestWidgetVisible && textInputFocus"
	},
	// suggestion
	{
		"key": "shift+cmd+i",
		"command": "github.copilot.terminal.suggestCommand",
		"when": "terminalFocus"
	},
	{
		"key": "cmd+i",
		"command": "-github.copilot.terminal.suggestCommand",
		"when": "terminalFocus"
	},
	{
		"key": "cmd+i",
		"command": "-inlineChat.start",
		"when": "editorFocus && inlineChatHasProvider && !editorReadonly"
	},
	// panel focus
	{
		"key": "cmd+j",
		"command": "workbench.action.focusPanel",
		"when": "!panelFocus"
	},
	// navigate tabs (in side bar): opt+cmd+arrow
	{
		"key": "alt+cmd+left",
		"command": "workbench.action.previousSideBarView",
		"when": "sideBarFocus"
	},
	{
		"key": "alt+cmd+right",
		"command": "workbench.action.nextSideBarView",
		"when": "sideBarFocus"
	},
	// navigate windows (in panel): opt+cmd+arrow
	{
		"key": "alt+cmd+left",
		"command": "-workbench.action.terminal.focusPreviousPane",
		"when": "terminalFocus && terminalHasBeenCreated || terminalFocus && terminalProcessSupported"
	},
	{
		"key": "ctrl+h",
		"command": "workbench.action.terminal.focusPreviousPane",
		"when": "terminalFocus && terminalHasBeenCreated || terminalFocus && terminalProcessSupported"
	},
	{
		"key": "alt+cmd+up",
		"command": "-workbench.action.terminal.focusPreviousPane",
		"when": "terminalFocus && terminalHasBeenCreated || terminalFocus && terminalProcessSupported"
	},
	{
		"key": "alt+cmd+right",
		"command": "-workbench.action.terminal.focusNextPane",
		"when": "terminalFocus && terminalHasBeenCreated || terminalFocus && terminalProcessSupported"
	},
	{
		"key": "ctrl+l",
		"command": "workbench.action.terminal.focusNextPane",
		"when": "terminalFocus && terminalHasBeenCreated || terminalFocus && terminalProcessSupported"
	},
	{
		"key": "alt+cmd+down",
		"command": "-workbench.action.terminal.focusNextPane",
		"when": "terminalFocus && terminalHasBeenCreated || terminalFocus && terminalProcessSupported"
	},
	{
		"key": "alt+cmd+down",
		"command": "workbench.action.terminal.focusNext",
		"when": "terminalFocus && terminalHasBeenCreated && !terminalEditorFocus || terminalFocus && terminalProcessSupported && !terminalEditorFocus"
	},
	{
		"key": "shift+cmd+]",
		"command": "-workbench.action.terminal.focusNext",
		"when": "terminalFocus && terminalHasBeenCreated && !terminalEditorFocus || terminalFocus && terminalProcessSupported && !terminalEditorFocus"
	},
	{
		"key": "alt+cmd+up",
		"command": "workbench.action.terminal.focusPrevious",
		"when": "terminalFocus && terminalHasBeenCreated && !terminalEditorFocus || terminalFocus && terminalProcessSupported && !terminalEditorFocus"
	},
	{
		"key": "shift+cmd+[",
		"command": "-workbench.action.terminal.focusPrevious",
		"when": "terminalFocus && terminalHasBeenCreated && !terminalEditorFocus || terminalFocus && terminalProcessSupported && !terminalEditorFocus"
	},
	{
		"key": "ctrl+h",
		"command": "workbench.action.navigateLeft",
		"when": "!panelFocus"
	},
	{
		"key": "ctrl+l",
		"command": "workbench.action.navigateRight",
		"when": "!panelFocus"
	},
	{
		"key": "ctrl+k",
		"command": "workbench.action.navigateUp"
	},
	{
		"key": "ctrl+j",
		"command": "workbench.action.navigateDown",
		"when": "!panelFocus"
	},
	// manage windows: ctrl+alt+cmd+arrow
	{
		"key": "cmd+k shift+cmd+left",
		"command": "-workbench.action.moveEditorLeftInGroup"
	},
	{
		"key": "ctrl+alt+cmd+left",
		"command": "workbench.action.moveEditorLeftInGroup"
	},
	{
		"key": "cmd+k shift+cmd+right",
		"command": "-workbench.action.moveEditorRightInGroup"
	},
	{
		"key": "ctrl+alt+cmd+right",
		"command": "workbench.action.moveEditorRightInGroup"
	},
	// resize windows: ctrl+alt+h/j/k/l
	{
		"key": "ctrl+alt+l",
		"command": "workbench.action.increaseViewWidth"
	},
	{
		"key": "ctrl+alt+h",
		"command": "workbench.action.decreaseViewWidth"
	},
	{
		"key": "ctrl+alt+j",
		"command": "workbench.action.decreaseViewHeight"
	},
	{
		"key": "ctrl+alt+k",
		"command": "workbench.action.increaseViewHeight"
	},
	// window split
	{
		"key": "ctrl+\\",
		"command": "workbench.action.splitEditor"
	},
	{
		"key": "cmd+\\",
		"command": "-workbench.action.splitEditor"
	},
	{
		"key": "ctrl+-",
		"command": "workbench.action.splitEditorOrthogonal"
	},
	{
		"key": "cmd+k cmd+\\",
		"command": "-workbench.action.splitEditorOrthogonal"
	},
	// resize terminal: ctrl+alt+h/j/k/l
	{
		"key": "ctrl+alt+j",
		"command": "workbench.action.terminal.resizePaneDown",
		"when": "!terminalEditorFocus && terminalFocus && terminalHasBeenCreated || !terminalEditorFocus && terminalFocus && terminalProcessSupported"
	},
	{
		"key": "ctrl+cmd+down",
		"command": "-workbench.action.terminal.resizePaneDown",
		"when": "terminalFocus && terminalHasBeenCreated || terminalFocus && terminalProcessSupported"
	},
	{
		"key": "ctrl+alt+h",
		"command": "workbench.action.terminal.resizePaneLeft",
		"when": "!terminalEditorFocus && terminalFocus && terminalHasBeenCreated || !terminalEditorFocus && terminalFocus && terminalProcessSupported"
	},
	{
		"key": "ctrl+cmd+left",
		"command": "-workbench.action.terminal.resizePaneLeft",
		"when": "terminalFocus && terminalHasBeenCreated || terminalFocus && terminalProcessSupported"
	},
	{
		"key": "ctrl+alt+l",
		"command": "workbench.action.terminal.resizePaneRight",
		"when": "!terminalEditorFocus && terminalFocus && terminalHasBeenCreated || !terminalEditorFocus && terminalFocus && terminalProcessSupported"
	},
	{
		"key": "ctrl+cmd+right",
		"command": "-workbench.action.terminal.resizePaneRight",
		"when": "terminalFocus && terminalHasBeenCreated || terminalFocus && terminalProcessSupported"
	},
	{
		"key": "ctrl+alt+k",
		"command": "workbench.action.terminal.resizePaneUp",
		"when": "!terminalEditorFocus && terminalFocus && terminalHasBeenCreated || !terminalEditorFocus && terminalFocus && terminalProcessSupported"
	},
	{
		"key": "ctrl+cmd+up",
		"command": "-workbench.action.terminal.resizePaneUp",
		"when": "terminalFocus && terminalHasBeenCreated || terminalFocus && terminalProcessSupported"
	},
	{
		"key": "cmd+w",
		"command": "workbench.action.terminal.kill",
		"when": "!terminalEditorFocus && terminalFocus && terminalHasBeenCreated || !terminalEditorFocus && terminalFocus && terminalProcessSupported"
	},
	// new terminal: shift+cmd+t
	{
		"key": "ctrl+shift+`",
		"command": "-workbench.action.terminal.new",
		"when": "terminalProcessSupported || terminalWebExtensionContributedProfile"
	},
	{
		"key": "shift+cmd+t",
		"command": "-workbench.action.reopenClosedEditor"
	},
	{
		"key": "shift+cmd+t",
		"command": "workbench.action.createTerminalEditorSameGroup",
	},
	{
		"key": "shift+cmd+t",
		"command": "workbench.action.terminal.new",
		"when": "terminalFocus && terminalHasBeenCreated && !terminalEditorFocus || terminalFocus && terminalProcessSupported && !terminalEditorFocus"
	},
	{
		"key": "shift+alt+cmd+t",
		"command": "workbench.action.terminal.openNativeConsole",
		"when": "!terminalFocus"
	},
	{
		"key": "shift+cmd+c",
		"command": "-workbench.action.terminal.openNativeConsole",
		"when": "!terminalFocus"
	},
	// terminal split
	{
		"key": "ctrl+\\",
		"command": "workbench.action.terminal.splitInstance",
		"when": "terminalProcessSupported && terminalTabsFocus"
	},
	{
		"key": "cmd+\\",
		"command": "-workbench.action.terminal.splitInstance",
		"when": "terminalProcessSupported && terminalTabsFocus"
	},
	{
		"key": "ctrl+\\",
		"command": "workbench.action.terminal.split",
		"when": "terminalFocus && terminalProcessSupported || terminalFocus && terminalWebExtensionContributedProfile"
	},
	{
		"key": "cmd+\\",
		"command": "-workbench.action.terminal.split",
		"when": "terminalFocus && terminalProcessSupported || terminalFocus && terminalWebExtensionContributedProfile"
	},
	{
		"key": "ctrl+\\",
		"command": "workbench.action.terminal.splitActiveTab",
		"when": "terminalProcessSupported && terminalTabsFocus"
	},
	{
		"key": "cmd+\\",
		"command": "-workbench.action.terminal.splitActiveTab",
		"when": "terminalProcessSupported && terminalTabsFocus"
	},
	// navigate backward/forward
	{
		"key": "ctrl+,",
		"command": "workbench.action.navigateBack",
		"when": "canNavigateBack"
	},
	{
		"key": "ctrl+-",
		"command": "-workbench.action.navigateBack",
		"when": "canNavigateBack"
	},
	{
		"key": "ctrl+,",
		"command": "workbench.action.quickInputBack",
		"when": "inQuickOpen"
	},
	{
		"key": "ctrl+-",
		"command": "-workbench.action.quickInputBack",
		"when": "inQuickOpen"
	},
	{
		"key": "ctrl+.",
		"command": "workbench.action.navigateForward",
		"when": "canNavigateForward"
	},
	{
		"key": "ctrl+shift+-",
		"command": "-workbench.action.navigateForward",
		"when": "canNavigateForward"
	},
	// move windows around: opt+ctrl+cmd+h/j/k/l
	{
		"key": "ctrl+alt+cmd+k",
		"command": "workbench.action.moveEditorToAboveGroup"
	},
	{
		"key": "ctrl+alt+cmd+j",
		"command": "workbench.action.moveEditorToBelowGroup"
	},
	{
		"key": "ctrl+alt+cmd+h",
		"command": "workbench.action.moveEditorToLeftGroup"
	},
	{
		"key": "ctrl+alt+cmd+l",
		"command": "workbench.action.moveEditorToRightGroup"
	},
	// quick fix
	{
		"key": "cmd+l",
		"command": "-expandLineSelection",
		"when": "textInputFocus"
	},
	{
		"key": "cmd+l",
		"command": "extension.multiCommand.execute",
		"args": {
			"sequence": [
				"cSpell.goToPreviousSpellingIssue",
				{
					"command": "editor.action.codeAction",
					"args": {
						"kind": "quickfix",
						"apply": "first"
					}
				},
				"cursorUndo",
			]
		}
	},
	// toggle excluded files
	{
		"key": "shift+cmd+.",
		"command": "toggleexcludedfiles.toggle",
		"when": "filesExplorerFocus"
	},
	{
		"key": "shift+cmd+a",
		"command": "-toggleexcludedfiles.toggle",
		"when": "filesExplorerFocus"
	},
	// rename
	{
		"key": "alt+enter",
		"command": "editor.action.rename",
		"when": "editorHasRenameProvider && editorTextFocus && !editorReadonly"
	},
	{
		"key": "f2",
		"command": "-editor.action.rename",
		"when": "editorHasRenameProvider && editorTextFocus && !editorReadonly"
	},
	// code runner
	{
		"key": "cmd+r",
		"command": "-workbench.action.reloadWindow",
		"when": "isDevelopment"
	},
	{
		"key": "cmd+r",
		"command": "code-runner.run"
	},
	{
		"key": "ctrl+alt+n",
		"command": "-code-runner.run"
	},
	// cycle relative/absolute line number
	{
		"key": "shift+space",
		"command": "settings.cycle.relativeLineNumber",
	},
	// paste image
	{
		"key": "alt+cmd+v",
		"command": "-extension.pasteImage",
		"when": "editorTextFocus"
	},
	{
		"key": "shift+cmd+v",
		"command": "extension.pasteImage",
		"when": "editorTextFocus"
	},
	// markdown show preview
	{
		"key": "cmd+k v",
		"command": "-markdown.showPreviewToSide",
		"when": "!notebookEditorFocused && editorLangId == 'markdown'"
	},
	{
		"key": "alt+cmd+v",
		"command": "markdown.showPreviewToSide",
		"when": "!notebookEditorFocused && editorLangId == 'markdown'"
	},
	{
		"key": "alt+cmd+v",
		"command": "markdown.extension.closePreview",
		"when": "markdownPreviewFocus"
	},
	{
		"key": "cmd+k v",
		"command": "-markdown.extension.closePreview",
		"when": "markdownPreviewFocus"
	},
	{
		"key": "shift+cmd+v",
		"command": "-markdown.extension.closePreview",
		"when": "markdownPreviewFocus"
	},
	{
		"key": "shift+cmd+v",
		"command": "-markdown.showPreview",
		"when": "!notebookEditorFocused && editorLangId == 'markdown'"
	},
	// markdown special toggle suggest
	{
		"key": "shift+cmd+i",
		"command": "editor.action.triggerSuggest",
		"when": "editorHasCompletionItemProvider && textInputFocus && !editorReadonly && editorLangId == 'markdown'"
	},
	// markdown else
	{
		"key": "shift+alt+c",
		"command": "markdown.extension.checkTaskList",
		"when": "editorTextFocus && editorLangId == 'markdown'"
	},
	{
		"key": "cmd+enter",
		"command": "-editor.action.openLink",
		"when": "editorTextFocus && editorLangId == 'markdown'"
	},
	{
		"key": "cmd+m",
		"command": "-markdown.extension.editing.toggleMath",
		"when": "editorTextFocus && !editorReadonly && editorLangId =~ /^markdown$|^rmd$|^qmd$/"
	},
	{
		"key": "cmd+i",
		"command": "markdown.extension.editing.toggleItalic",
		"when": "editorTextFocus && !editorReadonly && editorLangId =~ /^markdown$|^rmd$|^quarto$/ && editorHasSelection"
	},
	{
		"key": "cmd+i",
		"command": "-markdown.extension.editing.toggleItalic",
		"when": "editorTextFocus && !editorReadonly && editorLangId =~ /^markdown$|^rmd$|^quarto$/"
	},
	{
		"key": "cmd+b",
		"command": "markdown.extension.editing.toggleBold",
		"when": "editorTextFocus && !editorReadonly && editorLangId =~ /^markdown$|^rmd$|^quarto$/ && editorHasSelection"
	},
	{
		"key": "cmd+b",
		"command": "-markdown.extension.editing.toggleBold",
		"when": "editorTextFocus && !editorReadonly && editorLangId =~ /^markdown$|^rmd$|^quarto$/"
	},
	{
		"key": "cmd+b",
		"command": "workbench.action.toggleSidebarVisibility",
		"when": "!editorHasSelection"
	},
	{
		"key": "cmd+b",
		"command": "-workbench.action.toggleSidebarVisibility"
	},
	{
		"key": "cmd+m",
		"command": "-markdown.extension.editing.toggleMath",
		"when": "editorTextFocus && !editorReadonly && editorLangId =~ /^markdown$|^rmd$|^quarto$/"
	},
	{
		"key": "alt+d",
		"command": "-foam-vscode.open-daily-note"
	},
	{
		"key": "shift+cmd+r",
		"command": "jupyter.restartkernelandrunallcells"
	},
	{
		"key": "shift+alt+cmd+v",
		"command": "extension.paste-indent",
		"when": "editorTextFocus && !editorReadonly"
	},
	{
		"key": "cmd+i",
		"command": "-inlineChat2.reveal",
		"when": "inlineChatHasEditsAgent && !chatEdits.isGlobalEditingSession && chatEdits.requestCount >= 1"
	},
	{
		"key": "cmd+i",
		"command": "-workbench.action.terminal.chat.start",
		"when": "terminalChatAgentRegistered && terminalFocusInAny && terminalHasBeenCreated || terminalChatAgentRegistered && terminalFocusInAny && terminalProcessSupported"
	},
	{
		"key": "cmd+i",
		"command": "-inlineChat2.stop",
		"when": "inlineChatHasEditsAgent && inlineChatVisible && chatEdits.requestCount == '0'"
	},
	{
		"key": "cmd+i",
		"command": "-inlineChat.startWithCurrentLine",
		"when": "inlineChatHasProvider && inlineChatShowingHint && !editorReadonly && !inlineChatVisible"
	},
	{
		"key": "cmd+i",
		"command": "-inlineChat.start",
		"when": "editorFocus && inlineChatHasEditsAgent && inlineChatPossible && !editorReadonly && !editorSimpleInput || editorFocus && inlineChatHasProvider && inlineChatPossible && !editorReadonly && !editorSimpleInput"
	},
	{
		"key": "cmd+k i",
		"command": "-inlineChat.startWithCurrentLine",
		"when": "inlineChatHasProvider && !editorReadonly && !inlineChatVisible"
	},
	{
		"key": "alt+cmd+left",
		"command": "-workbench.action.terminal.focusPreviousPane",
		"when": "terminalFocus && terminalHasBeenCreated && terminalSplitPaneActive || terminalFocus && terminalProcessSupported && terminalSplitPaneActive"
	},
	{
		"key": "alt+cmd+right",
		"command": "-workbench.action.terminal.focusNextPane",
		"when": "terminalFocus && terminalHasBeenCreated && terminalSplitPaneActive || terminalFocus && terminalProcessSupported && terminalSplitPaneActive"
	},
	{
		"key": "shift+enter",
		"command": "workbench.action.terminal.sendSequence",
		"args": {
			"text": "\u001b\r"
		},
		"when": "terminalFocus"
	},
]