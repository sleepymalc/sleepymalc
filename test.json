{
	// window
	"window.titleBarStyle": "custom",
	"window.zoomLevel": -2,
	"window.commandCenter": false,
	"window.density.editorTabHeight": "compact",
	// workbench
	"workbench.settings.editor": "json",
	"workbench.startupEditor": "none",
	"workbench.iconTheme": "Monokai Pro Icons",
	"workbench.editor.editorActionsLocation": "hidden",
	"workbench.colorCustomizations": {
		"[Material Theme Palenight]": {
			"terminal.foreground": "#c5a0cd",
			"terminal.ansiBlack": "#79547d",
			"terminal.ansiBrightBlack": "#7b5b9d",
			"terminal.ansiBrightBlue": "#8d6aab",
			"terminal.ansiBlue": "#d58cb8",
			"terminal.selectionBackground": "#e59dff",
			"sideBar.border": "#1c4054",
			"activityBar.border": "#1c4054",
			"panel.border": "#1c4054",
			"editorLineNumber.foreground": "#8f5aa1",
			"editorLineNumber.activeForeground": "#bb33b7",
			"notebook.cellBorderColor": "#1c4054",
			"editor.findMatchHighlightBackground": "#8d5a5a65",
			"tree.indentGuidesStroke": "#37b2f0",
			"list.dropBackground": "#9c6dd06f",
			"sideBar.dropBackground": "#9c6dd06f",
			"editorGroup.dropBackground": "#9c6dd06f"
		},
		"[Vira*]": {
			"toolbar.activeBackground": "#80CBC426",
			"button.background": "#80CBC4",
			"button.hoverBackground": "#80CBC4cc",
			"extensionButton.separator": "#80CBC433",
			"extensionButton.background": "#80CBC414",
			"extensionButton.foreground": "#80CBC4",
			"extensionButton.hoverBackground": "#80CBC433",
			"extensionButton.prominentForeground": "#80CBC4",
			"extensionButton.prominentBackground": "#80CBC414",
			"extensionButton.prominentHoverBackground": "#80CBC433",
			"activityBarBadge.background": "#80CBC4",
			"activityBar.activeBorder": "#80CBC4",
			"activityBarTop.activeBorder": "#80CBC4",
			"list.inactiveSelectionIconForeground": "#80CBC4",
			"list.activeSelectionForeground": "#80CBC4",
			"list.inactiveSelectionForeground": "#80CBC4",
			"list.highlightForeground": "#80CBC4",
			"sash.hoverBorder": "#80CBC480",
			"list.activeSelectionIconForeground": "#80CBC4",
			"scrollbarSlider.activeBackground": "#80CBC480",
			"editorSuggestWidget.highlightForeground": "#80CBC4",
			"textLink.foreground": "#80CBC4",
			"progressBar.background": "#80CBC4",
			"pickerGroup.foreground": "#80CBC4",
			"tab.activeBorder": "#80CBC4",
			"notificationLink.foreground": "#80CBC4",
			"editorWidget.resizeBorder": "#80CBC4",
			"editorWidget.border": "#80CBC4",
			"settings.modifiedItemIndicator": "#80CBC4",
			"panelTitle.activeBorder": "#80CBC4",
			"breadcrumb.activeSelectionForeground": "#80CBC4",
			"menu.selectionForeground": "#80CBC4",
			"menubar.selectionForeground": "#80CBC4",
			"editor.findMatchBorder": "#80CBC4",
			"selection.background": "#80CBC440",
			"statusBarItem.remoteBackground": "#80CBC414",
			"statusBarItem.remoteHoverBackground": "#80CBC4",
			"statusBarItem.remoteForeground": "#80CBC4",
			"notebook.inactiveFocusedCellBorder": "#80CBC480",
			"commandCenter.activeBorder": "#80CBC480",
			"chat.slashCommandForeground": "#80CBC4",
			"chat.avatarForeground": "#80CBC4",
			"activityBarBadge.foreground": "#000000",
			"button.foreground": "#000000",
			"statusBarItem.remoteHoverForeground": "#000000"
		}
	},
	"workbench.tree.indent": 15,
	"workbench.tree.renderIndentGuides": "always",
	"workbench.editorAssociations": {
		"*.pdf": "pdf.preview"
	},
	"workbench.layoutControl.enabled": false,
	"workbench.activityBar.location": "bottom",
	// font
	"editor.fontFamily": "FiraCode-Retina",
	"scm.inputFontFamily": "FiraCode-Retina",
	"terminal.integrated.fontFamily": "FiraCode-Retina",
	"chat.editor.fontFamily": "FiraCode-Retina",
	"debug.console.fontFamily": "FiraCode-Retina",
	"editor.codeLensFontFamily": "FiraCode-Retina",
	"notebook.output.fontFamily": "FiraCode-Retina",
	"markdown.preview.fontFamily": "FiraCode-Retina",
	"editor.inlayHints.fontFamily": "FiraCode-Retina",
	"apc.font.family": "FiraCode-Retina",
	"apc.monospace.font.family": "FiraCode-Retina",
	// editor
	"editor.stickyScroll.enabled": true,
	"editor.linkedEditing": true,
	"editor.minimap.autohide": "mouseover",
	"editor.suggestSelection": "first",
	"editor.scrollbar.vertical": "auto",
	"editor.scrollbar.horizontal": "auto",
	"editor.lineNumbers": "on",
	"editor.insertSpaces": false,
	"editor.wordSeparators": "/\\()\"':,.;<>~!@#$%^&*|+=[]{}`?-",
	"editor.fontSize": 14,
	"editor.fontLigatures": true,
	"editor.padding.top": 6,
	"editor.guides.indentation": true,
	"editor.roundedSelection": true,
	"editor.smoothScrolling": true,
	"editor.cursorWidth": 1,
	"editor.glyphMargin": false,
	"editor.inlayHints.enabled": "off",
	"editor.inlayHints.padding": true,
	"editor.accessibilitySupport": "off",
	"editor.scrollbar.verticalScrollbarSize": 9,
	"editor.scrollbar.horizontalScrollbarSize": 9,
	"editor.cursorBlinking": "phase",
	"editor.matchBrackets": "never",
	"editor.bracketPairColorization.enabled": true,
	"editor.bracketPairColorization.independentColorPoolPerBracketType": true,
	"editor.guides.bracketPairs": true,
	"editor.inlineSuggest.enabled": true,
	"editor.formatOnSave": true,
	"editor.formatOnPaste": true,
	"editor.cursorSmoothCaretAnimation": "on",
	// "editor.codeActionsOnSave": {
	// 	"source.fixAll.markdownlint": "explicit"
	// },
	"editor.quickSuggestions": {
		"other": true,
		"comments": true,
		"strings": true
	},
	"editor.cursorStyle": "line",
	"editor.wordWrap": "on",
	// "editor.cursorSurroundingLines": 15,
	"editor.tabCompletion": "off",
	"editor.detectIndentation": false,
	"editor.tabSize": 4,
	//subtle brackets
	"subtleBrackets.disableNative": false,
	// APC
	"apc.electron": {
		"titleBarStyle": "hidden",
	},
	"apc.header": {
		"height": 35
	},
	"apc.activityBar": {
		"position": "bottom",
		"size": 40,
		"itemMargin": 0,
	},
	"apc.statusBar": {
		"position": "bottom",
		"height": 20,
		"fontSize": 13
	},
	"apc.sidebar.titlebar": {
		"height": 35,
	},
	"apc.stylesheet": {
		".title-label": "display: none !important",
		".title-actions": "margin-left: auto !important",
		".quick-input-widget": {
			"position": "absolute !important",
			"top": "30% !important",
			"left": "50%",
			"border-radius": "10px",
			"border": "1px solid var(--vscode-textSeparator-foreground) !important",
			"box-shadow": "0 0 60px 0 rgba(0,0,0,0.2) !important"
		},
		// ".split-view-view + .split-view-view.visible .tabs-container": "padding-left: 0px",
		// ".split-view-view.visible + .split-view-view.visible .tabs-container": "padding-left: 0px",
		".basepanel .title": "padding-left: 0px !important",
	},
	// explorer
	"explorer.confirmDelete": false,
	"explorer.confirmDragAndDrop": false,
	// TODO Tree
	"todo-tree.general.tags": [
		"TODO",
		"[x]",
	],
	"todo-tree.highlights.defaultHighlight": {
		"icon": "alert",
		"type": "text-and-comment",
		"foreground": "black",
		"background": "white",
		"opacity": 50,
		"iconColour": "blue",
		"gutterIcon": true,
	},
	"todo-tree.highlights.customHighlight": {
		"TODO": {
			"icon": "circle",
			"foreground": "white",
			"background": "#bf00ff",
			"iconColour": "#be56b2",
		},
		"[x]": {
			"icon": "check-circle-fill",
			"foreground": "black",
			"background": "#a294c1",
			"iconColour": "#a294c1",
		},
		"Write up": {
			"icon": "note",
			"foreground": "white",
			"background": "gray",
			"iconColour": "gray",
		}
	},
	// vim
	"vim.easymotion": true,
	"vim.easymotionDimBackground": false,
	"vim.sneak": true,
	"vim.incsearch": true,
	"vim.hlsearch": true,
	"vim.leader": "<space>",
	"vim.normalModeKeyBindingsNonRecursive": [
		{
			"before": [
				"down"
			],
			"after": [
				"g",
				"j"
			]
		},
		{
			"before": [
				"up"
			],
			"after": [
				"g",
				"k"
			]
		},
		{
			"before": [
				"j"
			],
			"after": [
				"g",
				"j"
			]
		},
		{
			"before": [
				"k"
			],
			"after": [
				"g",
				"k"
			]
		},
		{
			"before": [
				"<Leader>",
				"/"
			],
			"commands": [
				":noh"
			]
		}
	],
	"vim.visualModeKeyBindingsNonRecursive": [
		{
			"before": [
				"down"
			],
			"after": [
				"g",
				"j"
			]
		},
		{
			"before": [
				"up"
			],
			"after": [
				"g",
				"k"
			]
		},
		{
			"before": [
				"j"
			],
			"after": [
				"g",
				"j"
			]
		},
		{
			"before": [
				"k"
			],
			"after": [
				"g",
				"k"
			]
		}
	],
	// Terminal
	"terminal.integrated.env.osx": {
		"Q_NEW_SESSION": "1",
		"FIG_NEW_SESSION": "1"
	},
	"terminal.explorerKind": "external",
	"terminal.external.osxExec": "iTerm.app",
	"terminal.integrated.fontSize": 14,
	"terminal.integrated.cursorBlinking": true,
	"terminal.integrated.enableMultiLinePasteWarning": "never",
	"terminal.integrated.suggest.enabled": true,
	"terminal.integrated.inheritEnv": true,
	"terminal.integrated.shellIntegration.enabled": true,
	// GitHub Copilot
	"github.copilot.enable": {
		"*": false,
		"plaintext": true,
		"markdown": true,
		"scminput": false,
		"yaml": false,
		"latex": false,
		"python": false
	},
	// command-runner
	"command-runner.terminal.name": "runCommand",
	"command-runner.terminal.autoClear": true,
	"command-runner.terminal.autoFocus": false,
	"command-runner.commands": {
		"inkscapeCreate": "inkscape-figures create ${selectedText} ${workspaceFolder}/Figures/",
		"inkscapeEdit": "inkscape-figures edit ${workspaceFolder}/Figures/",
		"inkscapeStart": "inkscape-figures watch",
		"quiver": "arc-cli new-little-arc https://q.uiver.app/"
	},
	// setting.cycle
	"settings.cycle": [
		{
			"id": "relativeLineNumber",
			"overrideWorkspaceSettings": false,
			"values": [
				{
					"editor.lineNumbers": "on"
				},
				{
					"editor.lineNumbers": "relative"
				}
			]
		}
	],
	// cSpell
	"cSpell.diagnosticLevel": "Warning",
	"cSpell.customDictionaries": {
		"custom-dictionary-user": {
			"name": "custom-dictionary-user",
			"path": "~/.cspell/custom-dictionary-user.txt",
			"addWords": true,
			"scope": "user"
		}
	},
	"cSpell.userWords": [
		"Hu",
		"Pingbang",
		"cd",
		"EECS",
		"infimum",
		"supremum",
		"Inkscape",
		"mac",
		"Mathematica",
		"pingbang",
		"pmat"
	],
	// debug
	"launch": {
		"version": "0.2.0",
		"configurations": [
			{
				"name": "(lldb) Launch",
				"type": "lldb",
				"request": "launch",
				"program": "${workspaceFolder}/zoo_debug",
				"args": [],
				"stdio": [
					//stdin
					"test/test.txt",
					//stdout
					"output.txt",
					//stderr
					null
				],
				"cwd": "${workspaceFolder}"
			}
		]
	},
	// C_Cpp
	"C_Cpp.default.cppStandard": "c++17",
	"C_Cpp.default.cStandard": "c17",
	"C_Cpp.default.intelliSenseMode": "macos-clang-x86",
	"C_Cpp.autocompleteAddParentheses": true,
	"C_Cpp.clang_format_fallbackStyle": "{BasedOnStyle: Google, IndentWidth: 4, ColumnLimit: 0 }",
	"C_Cpp.commentContinuationPatterns": [
		"/**"
	],
	// python
	"python.analysis.completeFunctionParens": true,
	"python.languageServer": "Pylance",
	"pythonIndent.trimLinesWithOnlyWhitespace": true,
	"jupyter.askForKernelRestart": false,
	"notebook.lineNumbers": "on",
	"[python]": {
		"editor.insertSpaces": true,
		"editor.tabSize": 4
	},
	//json
	"[json]": {
		"editor.quickSuggestions": {
			"strings": true
		},
		"editor.suggest.insertMode": "replace"
	},
	// LaTeX
	"[latex]": {
		"editor.formatOnPaste": false,
		"editor.suggestSelection": "recentlyUsedByPrefix",
		"editor.tabCompletion": "on"
	},
	// LaTeX-Workshop
	"latex-workshop.view.pdf.viewer": "tab",
	"latex-workshop.latex.autoBuild.run": "onSave",
	"latex-workshop.latex.clean.fileTypes": [
		"*.aux",
		"*.bbl",
		"*.blg",
		"*.idx",
		"*.ind",
		"*.lof",
		"*.lot",
		"*.out",
		"*.toc",
		"*.acn",
		"*.acr",
		"*.alg",
		"*.glg",
		"*.glo",
		"*.gls",
		"*.fls",
		"*.log",
		"*.fdb_latexmk",
		"*.snm",
		"*.synctex(busy)",
		"*.synctex.gz(busy)"
	],
	"latex-workshop.linting.chktex.enabled": true,
	"latex-workshop.latex.autoClean.run": "onBuilt",
	"latex-workshop.view.pdf.invert": 0.9,
	"latex-workshop.view.pdf.invertMode.enabled": "auto",
	"latex-workshop.intellisense.package.enabled": true,
	"latex-workshop.hover.preview.scale": 1.5,
	"latex-workshop.hover.preview.mathjax.extensions": [
		"cases",
		"cancel",
		"mathtools",
		"physics"
	],
	// Markdown
	"[markdown]": {
		"editor.defaultFormatter": "yzhang.markdown-all-in-one",
	},
	"markdown.preview.fontSize": 16,
	"markdown.preview.scrollEditorWithPreview": false,
	"markdown.preview.scrollPreviewWithEditor": false,
	"markdown.extension.toc.levels": "2..4",
	"markdown.extension.tableFormatter.normalizeIndentation": true,
	"markdown.extension.print.theme": "dark",
	"markdown.links.openLocation": "beside",
	// markdownlint
	"markdownlint.config": {
		"[markdown]": {
			"editor.formatOnSave": true,
			"editor.formatOnPaste": true
		},
		"MD010": false,
		"MD024": false,
		"MD033": false,
	},
	// pastImage
	"pasteImage.defaultName": "Y-MM-DD-HH-mm-ss",
	"pasteImage.path": "${projectRoot}/assets/images/${currentFileNameWithoutExt}",
	"pasteImage.showFilePathConfirmInputBox": true,
	"pasteImage.insertPattern": "![[${imageFileName}]]",
	// memo
	"memo.links.rules": [
		"${workspaceFolder}/Note/Random",
	],
	// foam
	"foam.graph.style": {
		"fontSize": 16,
		"highlightedForeground": "#f9c74f",
		"node": {
			"note": "#277da1",
			"placeholder": "#545454"
		}
	},
	"foam.graph.titleMaxLength": 10,
	"foam.links.hover.enable": false,
	// files exclude
	"toggleexcludedfiles.explorer.enabled": false,
	"toggleexcludedfiles.statusBar.enabled": false,
	// files
	"files.exclude": {
		".viceroy": false,
		"apollo-overrides": false,
		"release-info": false,
		"src/*/build": false,
		"build": false,
		"env": false,
		"packageInfo*": false,
		".bemol": false,
		"**/.git": false,
		"**/.svn": false,
		"**/.hg": false,
		"**/.DS_Store": false,
		"**/Thumbs.db": false,
		"**/.*": false
	},
	"files.trimTrailingWhitespace": true,
	// git
	"git.confirmSync": false,
	"git.openRepositoryInParentFolders": "always",
	"git.enableSmartCommit": true,
	"security.workspace.trust.untrustedFiles": "newWindow",
	"remote.SSH.configFile": "~/.ssh/config",
	"grammarly.files.include": [
		"**/*.md",
		"**/*.txt",
	],
	"extensions.experimental.affinity": {
		"vscodevim.vim": 1,
	},
	"breadcrumbs.filePath": "on",
	"explorer.confirmPasteNative": false,
	"github.copilot.editor.enableAutoCompletions": true,
	"git.ignoreRebaseWarning": true,
	"gitlens.launchpad.indicator.enabled": false,
	"workbench.colorTheme": "Material Theme Palenight",
	"lldb.suppressUpdateNotifications": true,
	"print.folder.fileNames": true,
	"print.folder.include": [],
	"print.folder.exclude": [
		"{bin,obj,out}",
		"node_modules",
		"data",
		"**/*.{bin,exe,dll,hex,pdb,pdf,pfx,png,jpg,gif,bmp,suo,design}"
	],
	"print.folder.maxLines": 1200,
	"print.folder.maxFiles": 30,
	"print.folder.includeFileList": false,
	"python.defaultInterpreterPath": "/opt/homebrew/bin/python3",
	"telemetry.telemetryLevel": "off",
	"telemetry.enableCrashReporter": false,
	"telemetry.enableTelemetry": false,
	"workbench.settings.enableNaturalLanguageSearch": false,
	"workbench.commandPalette.experimental.enableNaturalLanguageSearch": false,
	"viceroy.config.lastVersion": "0.53.202244",
	"files.watcherExclude": {
		"**/build/**": true,
		"**/.git/objects/**": true,
		"**/.git/subtree-cache/**": true,
		"**/.hg/store/**": true
	},
	"search.exclude": {
		"env": true,
		"src/*/build": true,
		"build": true,
		"**/node_modules": true,
		"**/bower_components": true,
		"**/*.code-search": true
	},
	"editor.largeFileOptimizations": false,
	"github.copilot.nextEditSuggestions.enabled": false,
	"claudeCode.preferredLocation": "panel",
	"claudeCode.selectedModel": "default",
	"githubPullRequests.createOnPublishBranch": "never",
	"terminal.integrated.initialHint": false,
}